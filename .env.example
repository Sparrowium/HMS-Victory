# ============================================
# Network Automation & Monitoring Stack
# Environment Variables Template
# ============================================

# --- Grafana ---
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=
GRAFANA_ROOT_URL=

# --- SNMP (v2c communities – change to your actual values) ---
SNMP_COMMUNITY_JUNIPER=
SNMP_COMMUNITY_ARISTA=
SNMP_COMMUNITY_APC=

# --- SNMP Target Device IPs (replace with your real IPs) ---
SNMP_TARGET_JUNIPER=
SNMP_TARGET_ARISTA=
SNMP_TARGET_APC=

# --- VictoriaMetrics ---
VM_RETENTION_PERIOD=
VM_HTTP_LISTEN_ADDR=

# --- VictoriaLogs ---
VLOG_HTTP_LISTEN_ADDR=

# --- CoreDNS ---
# Upstream DNS servers (space separated)
COREDNS_UPSTREAM=

# --- Nginx ---
NGINX_PORT=

# --- Docker Networks ---
# External network for cross-project communication (optional)
SHARED_NETWORK=
